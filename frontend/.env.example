# Kaba Frontend - Environment Variables
# Copy to .env.local and adjust as needed

# Backend API base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:3001

# KkiaPay widget (Benin / West Africa payments)
# Public key from https://app.kkiapay.me > Developers > API Keys
NEXT_PUBLIC_KKIAPAY_PUBLIC_KEY=
NEXT_PUBLIC_KKIAPAY_SANDBOX=true

# Optional: Demo business ID for development when not logged in
# NEXT_PUBLIC_DEMO_BUSINESS_ID=your-demo-business-id

# Enable Service Worker on localhost for offline testing during development
# NEXT_PUBLIC_ENABLE_SW_LOCALHOST=true
