{
  "name": "kaba-backend",
  "version": "1.0.0",
  "description": "Kaba - MSME accounting SaaS for West Africa",
  "main": "dist/nest/main.js",
  "scripts": {
    "dev": "ts-node -r tsconfig-paths/register src/nest/main.ts",
    "build": "tsc",
    "start": "node dist/nest/main.js",
    "test": "jest",
    "test:integration": "jest --testPathPattern='api\\.integration|PaymentsClient\\.integration|MoMo\\.e2e' --no-coverage",
    "test:payments": "jest --testPathPattern='PaymentsClient\\.integration|MoMo\\.e2e' --no-coverage",
    "test:momo:live": "MOMO_E2E_LIVE=1 jest --testPathPattern='MoMo\\.e2e' --no-coverage",
    "lint": "eslint \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "cdk:synth": "cdk synth -c environment=dev",
    "cdk:deploy": "cdk deploy -c environment=dev --all --require-approval never --no-previous-parameters",
    "cdk:deploy:full": "npm run build && npm run bundle && cdk deploy -c environment=dev --all --require-approval never --no-previous-parameters",
    "cdk:deploy:staging": "cdk deploy -c environment=staging --all --require-approval never --no-previous-parameters",
    "cdk:deploy:prod": "cdk deploy -c environment=prod --all --require-approval broadening --no-previous-parameters",
    "bundle": "node scripts/bundle-lambda.js",
    "seed": "ts-node -r tsconfig-paths/register scripts/seed.ts",
    "seed:demo": "ts-node -r tsconfig-paths/register scripts/seed-demo.ts",
    "fix-dev": "ts-node -r tsconfig-paths/register scripts/fix-dev-user.ts",
    "set-user-password": "ts-node -r tsconfig-paths/register scripts/set-user-password.ts",
    "create-momo-apiuser": "node scripts/create-momo-apiuser.mjs",
    "sync-google-oauth-secret": "node scripts/sync-google-oauth-secret.mjs",
    "sync-secrets": "node scripts/sync-secrets-from-env.mjs",
    "fetch-dev-env": "node scripts/fetch-dev-env.mjs",
    "mecef:sandbox-test": "node scripts/mecef-sandbox-test.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.882.0",
    "@aws-sdk/client-eventbridge": "^3.958.0",
    "@aws-sdk/client-s3": "^3.958.0",
    "@aws-sdk/client-secrets-manager": "^3.958.0",
    "@aws-sdk/client-ses": "^3.1002.0",
    "@aws-sdk/client-sns": "^3.958.0",
    "@aws-sdk/lib-dynamodb": "^3.882.0",
    "@aws-sdk/s3-request-presigner": "^3.958.0",
    "@codegenie/serverless-express": "^4.17.1",
    "@google/generative-ai": "^0.24.1",
    "@nestjs/common": "^11.1.14",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.14",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.14",
    "@nestjs/throttler": "^6.5.0",
    "@sentry/node": "^10.43.0",
    "@sentry/profiling-node": "^10.43.0",
    "@types/qrcode": "^1.5.6",
    "africastalking": "^0.7.9",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.6.1",
    "helmet": "^8.1.0",
    "openai": "^6.27.0",
    "opossum": "^9.0.0",
    "p-retry": "^7.1.1",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.15.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "stripe": "^20.4.0",
    "twilio": "^5.12.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@anatine/esbuild-decorators": "^0.2.19",
    "@nestjs/testing": "^11.1.16",
    "@types/aws-lambda": "^8.10.152",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.10.0",
    "@types/opossum": "^8.1.9",
    "@types/passport-facebook": "^3.0.0",
    "@types/passport-google-oauth20": "^2.0.14",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdfkit": "^0.13.4",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "aws-cdk": "^2.214.0",
    "aws-cdk-lib": "^2.214.0",
    "constructs": "^10.0.0",
    "esbuild": "^0.24.0",
    "eslint": "^10.0.3",
    "jest": "^29.7.0",
    "nock": "^14.0.11",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
