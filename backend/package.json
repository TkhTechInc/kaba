{
  "name": "quickbooks-west-africa-backend",
  "version": "1.0.0",
  "description": "QuickBooks-like MSME accounting SaaS for West Africa",
  "main": "dist/nest/main.js",
  "scripts": {
    "dev": "ts-node -r tsconfig-paths/register src/nest/main.ts",
    "build": "tsc",
    "start": "node dist/nest/main.js",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "type-check": "tsc --noEmit",
    "cdk:synth": "cdk synth -c environment=dev",
    "cdk:deploy": "cdk deploy -c environment=dev --all --require-approval never",
    "cdk:deploy:full": "npm run build && npm run bundle && cdk deploy -c environment=dev --all --require-approval never",
    "cdk:deploy:staging": "cdk deploy -c environment=staging --all --require-approval never",
    "cdk:deploy:prod": "cdk deploy -c environment=prod --all --require-approval broadening",
    "bundle": "node scripts/bundle-lambda.js",
    "seed": "ts-node -r tsconfig-paths/register scripts/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.882.0",
    "@aws-sdk/client-eventbridge": "^3.958.0",
    "@aws-sdk/client-s3": "^3.958.0",
    "@aws-sdk/client-secrets-manager": "^3.958.0",
    "@aws-sdk/client-ses": "^3.1002.0",
    "@aws-sdk/client-sns": "^3.958.0",
    "@aws-sdk/lib-dynamodb": "^3.882.0",
    "@aws-sdk/s3-request-presigner": "^3.958.0",
    "@codegenie/serverless-express": "^4.17.1",
    "@google/generative-ai": "^0.24.1",
    "@nestjs/common": "^11.1.14",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.14",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.14",
    "@nestjs/throttler": "^6.5.0",
    "africastalking": "^0.7.9",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "dotenv": "^16.6.1",
    "helmet": "^8.1.0",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.15.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "stripe": "^20.4.0",
    "twilio": "^5.12.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@anatine/esbuild-decorators": "^0.2.19",
    "@types/aws-lambda": "^8.10.152",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.10.0",
    "@types/passport-facebook": "^3.0.0",
    "@types/passport-google-oauth20": "^2.0.14",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdfkit": "^0.13.4",
    "@types/uuid": "^9.0.0",
    "aws-cdk": "^2.214.0",
    "aws-cdk-lib": "^2.214.0",
    "constructs": "^10.0.0",
    "esbuild": "^0.24.0",
    "jest": "^29.7.0",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
