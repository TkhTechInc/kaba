# Kaba Backend - Environment Variables
# Copy to .env and adjust as needed

# JWT secret (required in production). Lambda uses Secrets Manager (see docs/AUTH_DEPLOY.md)
JWT_SECRET=your-secret-key

# -----------------------------------------------------------------------------
# Error Tracking & Monitoring (Sentry)
# -----------------------------------------------------------------------------
# Get your DSN from https://sentry.io
SENTRY_DSN=
SENTRY_RELEASE=1.0.0

# -----------------------------------------------------------------------------
# Launch promo: enable all features for all tiers for first 6 months after launch
# Set LAUNCH_PROMO_ENABLED=true and LAUNCH_PROMO_END_DATE=YYYY-MM-DD (e.g. 2025-09-01)
# When active: all users get enterprise-tier feature access regardless of plan
# -----------------------------------------------------------------------------
# LAUNCH_PROMO_ENABLED=true
# LAUNCH_PROMO_END_DATE=2025-09-01

# DynamoDB tables (for local dev pointing at AWS). CDK sets these for Lambda.
# DYNAMODB_LEDGER_TABLE=Kaba-LedgerService-dev-ledger
# DYNAMODB_INVOICES_TABLE=Kaba-Invoices-dev
# DYNAMODB_AUDIT_LOGS_TABLE=Kaba-AuditLogs-dev-audit
# DYNAMODB_IDEMPOTENCY_TABLE=Kaba-Idempotency-dev

# Admin access - comma-separated phone numbers and/or emails
ADMIN_PHONES=+2348012345678
ADMIN_EMAILS=admin@example.com

# OAuth - for Google and Facebook sign-in
# Get credentials from Google Cloud Console and Facebook Developer
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3001/api/v1/auth/facebook/callback

# Where to redirect after OAuth (your frontend URL)
# Use http://localhost:3008 if frontend runs on port 3008
FRONTEND_URL=http://localhost:3000

# Public URL of this API (trust share links, webhooks, etc.)
# Local: http://localhost:3001 | Production: https://api.kabasika.com
API_URL=http://localhost:3001

# OTP expiry in minutes (default 10)
OTP_TTL_MINUTES=10

# -----------------------------------------------------------------------------
# SMS Provider for OTP & receipts (choose one: aws_sns | twilio | africastalking)
# -----------------------------------------------------------------------------
# AWS SNS: ~$0.013/msg Canada, ~$0.008-0.02 West Africa. No free tier.
# New accounts: $1/month default limit. For local: AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY.
# Dev without SMS: set SMS_ENABLED=false – OTP is logged to console.
# -----------------------------------------------------------------------------
SMS_PROVIDER=aws_sns
SMS_ENABLED=true
SMS_SENDER_ID=Kaba

# --- AWS SNS (uses AWS credentials from env/instance role) ---
# Canada: ca-central-1 | West Africa: af-south-1
AWS_REGION=ca-central-1

# --- Twilio (https://console.twilio.com) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Africa's Talking (https://account.africastalking.com) ---
AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=
AFRICASTALKING_SENDER_ID=Kaba
# Voice OTP: virtual phone number from Africa's Talking (for outbound calls)
AFRICASTALKING_VOICE_PHONE=

# USSD: callback URL for Africa's Talking USSD (configure in Africa's Talking dashboard)
USSD_CALLBACK_URL=https://api.xxx.execute-api.region.amazonaws.com/api/v1/ussd/callback

# -----------------------------------------------------------------------------
# WhatsApp (for receipts, debt reminders). mock | meta | meta_cloud | twilio | africastalking
# -----------------------------------------------------------------------------
WHATSAPP_PROVIDER=mock

# --- Meta Cloud API (https://developers.facebook.com/docs/whatsapp/cloud-api) ---
# Get from Meta Business Suite > WhatsApp > API Setup. Required when WHATSAPP_PROVIDER=meta or meta_cloud.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# -----------------------------------------------------------------------------
# S3 Storage (required for WhatsApp invoice PDFs, receipt uploads)
# -----------------------------------------------------------------------------
# Create a bucket in AWS S3; CDK sets this for Lambda. For local dev, use a real bucket or deploy ReceiptsStorageStack.
# S3_RECEIPTS_BUCKET=

# -----------------------------------------------------------------------------
# AI (LLM) – receipts, mobile money parsing, voice, loan readiness. Uses mock if unset.
# -----------------------------------------------------------------------------
# Provider: claude | openai | bedrock | gemini | openrouter
AI_PROVIDER=openrouter
AI_MODEL=deepseek/deepseek-chat-v3-0324:free

# --- OpenRouter (multi-model, cost-effective for early stage) ---
# Get key at https://openrouter.ai/keys
# Free models: deepseek/deepseek-chat-v3-0324:free | meta-llama/llama-3.2-3b-instruct:free
OPENROUTER_API_KEY=

# --- Claude (Anthropic) ---
ANTHROPIC_API_KEY=

# --- OpenAI ---
OPENAI_API_KEY=

# --- Google Gemini ---
GEMINI_API_KEY=

# --- AWS Bedrock (uses AWS credentials from env/instance role) ---
AI_BEDROCK_REGION=us-east-1

# -----------------------------------------------------------------------------
# Mobile Money SMS Parser (MTN MoMo, Moov). mock = throws, llm = uses AI_PROVIDER
# -----------------------------------------------------------------------------
MOBILE_MONEY_PARSER_PROVIDER=mock

# -----------------------------------------------------------------------------
# Receipt PDF Generator. mock = placeholder, pdfkit = real PDF with logo
# -----------------------------------------------------------------------------
RECEIPT_PDF_PROVIDER=mock

# -----------------------------------------------------------------------------
# Email (verification codes, forgot password, invitations). Uses AWS SES.
# When disabled: reset links and codes are logged to backend console only.
# -----------------------------------------------------------------------------
EMAIL_ENABLED=true
AWS_SES_REGION=ca-central-1
AWS_SES_FROM=noreply@kabasika.com
# Or: EMAIL_FROM=noreply@yourdomain.com
# SES sender must be verified in AWS SES. Sandbox: only verified recipients.
# Uses AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY (same as DynamoDB/SNS).

# -----------------------------------------------------------------------------
# TKH Payments (required — all payments go through TKH Payments aggregator)
# -----------------------------------------------------------------------------
# See backend/docs/TKH_PAYMENTS_API.md for API contract.
# TKH Payments handles KkiaPay, MoMo, Moov Africa, Stripe, Paystack, etc.
PAYMENTS_SERVICE_URL=https://dev-payments.tkhtech.com/api/v1
# Optional API key sent as X-API-Key when TKH Payments requires auth.
TKH_PAYMENTS_API_KEY=

# MoMo local/sandbox test controls for this app backend (not TKH Payments service).
# Use these only for local UX/testing when profile currency/country differs from test lane.
# Example EUR test lane:
# MOMO_TEST_FORCE_GH=false
# MOMO_TEST_CURRENCY=EUR
# MOMO_TEST_COUNTRY=
# MOMO_TEST_FORCE_MOMO_UI=true
# KKIAPAY_TEST_FORCE_UI=true
# MOMO_TEST_MOCK_SUCCESS=false
MOMO_TEST_FORCE_GH=false
MOMO_TEST_CURRENCY=
MOMO_TEST_COUNTRY=
MOMO_TEST_FORCE_MOMO_UI=false
KKIAPAY_TEST_FORCE_UI=false
# Optional dev fallback when business/customer phone is missing for KkiaPay intent.
KKIAPAY_TEST_PHONE_NUMBER=
# If true, return local success when upstream MoMo request fails.
MOMO_TEST_MOCK_SUCCESS=false

# -----------------------------------------------------------------------------
# Payment Gateways (legacy — used by TKH Payments, not Kaba directly)
# -----------------------------------------------------------------------------
# Gateways are selected by business countryCode from onboarding, not just currency.
# BJ/TG/CI/SN/ML/NE/BF → KkiaPay primary | GH → MoMo primary | NG → Stripe | etc.

# Stripe (NG, USD, EUR, GBP and more)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# KkiaPay (XOF, XAF, GNF — West Africa: Benin, Togo, Ivory Coast)
KKIAPAY_PRIVATE_KEY=
KKIAPAY_WEBHOOK_SECRET=
KKIAPAY_BASE_URL=https://api.kkiapay.me
# KKIAPAY_SANDBOX=true — when using widget sandbox; 404 from status API is trusted as success
# KKIAPAY_PUBLIC_KEY — for KkiaPay widget (returned in plan pay data; frontend uses it or NEXT_PUBLIC_KKIAPAY_PUBLIC_KEY)
KKIAPAY_PUBLIC_KEY=

# MTN Mobile Money (XOF, XAF, GNF, GHS)
# Run: MOMO_SUBSCRIPTION_KEY=<key> npm run create-momo-apiuser  (creates MOMO_API_USER + MOMO_API_KEY)
MOMO_API_KEY=
MOMO_SUBSCRIPTION_KEY=
MOMO_API_USER=
MOMO_WEBHOOK_SECRET=
MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MOMO_TARGET_ENV=sandbox
# Disbursement (payouts): subscribe to Disbursements product, then run with MOMO_DISBURSEMENT_SUBSCRIPTION_KEY
MOMO_DISBURSEMENT_API_USER=
MOMO_DISBURSEMENT_API_KEY=
MOMO_DISBURSEMENT_SUBSCRIPTION_KEY=

# Moov Africa Merchant API (Benin, Togo — XOF). No public portal; contact Moov Africa for merchant signup.
# See backend/docs/MOOV_AFRICA.md
MOOV_AFRICA_USERNAME=
MOOV_AFRICA_PASSWORD=
# MOOV_AFRICA_BASE_URL=https://testapimarchand2.moov-africa.bj:2010/com.tlc.merchant.api/UssdPush
# MOOV_AFRICA_ENCRYPTION_KEY=tlc12345tlc12345tlc12345tlc12345
# MOOV_AFRICA_SANDBOX=true

# -----------------------------------------------------------------------------
# Fiscal certification (e-MECeF Benin, FNE Côte d'Ivoire). Stubs used when unset.
# -----------------------------------------------------------------------------
# Benin e-MECeF: JWT from developper.impots.bj (sandbox) or sygmef.impots.bj (prod)
# Get sandbox JWT: https://developper.impots.bj → register → API token
# Test: MECEF_BENIN_JWT=xxx npm run mecef:sandbox-test
MECEF_BENIN_JWT=
MECEF_BENIN_BASE_URL=https://developper.impots.bj
# MECEF_TEST_IFU=3202200000001  # optional; test IFU for sandbox script

# Côte d'Ivoire FNE: API key from services.fne.dgi.gouv.ci
FNE_CI_API_KEY=
FNE_CI_BASE_URL=https://services.fne.dgi.gouv.ci

# -----------------------------------------------------------------------------
# Integration tests (optional). Loaded by jest.setup.js.
# -----------------------------------------------------------------------------
# INTEGRATION_TEST_EMAIL=lloydharold14@gmail.com
# INTEGRATION_TEST_PASSWORD=your-password
# INTEGRATION_TEST_API_URL=http://localhost:3001
